{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "apphosting": [
    {
      "backend": {
        "backendId": "georecorregut-backend",
        "region": "europe-west4",
        "rootDir": "/",
        "env": {
          "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY": {
            "secret": "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY"
          },
          "NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID": {
            "secret": "NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID"
          },
          "GEMINI_API_KEY": {
            "secret": "GEMINI_API_KEY"
          },
          "GOOGLE_API_KEY": {
            "secret": "GOOGLE_API_KEY"
          }
        }
      },
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ],
      "alwaysDeployFromSource": true
    },
    {
      "backendId": "georecorregut-backend",
      "rootDir": "/",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ]
    }
  ]
}
